# Copy to .env (gitignored) and fill in. Sourced by scripts/jira-init.sh.
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Used by .mcp.json to authenticate the Context7 MCP server.
# Local: export from .env. CI: add as the CONTEXT7_API_KEY repo secret.
# Generate at: https://context7.com/dashboard
CONTEXT7_API_KEY=
