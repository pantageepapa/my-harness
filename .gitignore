# Local secrets — JIRA_API_TOKEN etc. Sourced by scripts/jira-init.sh.
.env

# Per-clone Jira CLI config — generated by scripts/jira-init.sh.
# Each consumer wires their own instance / project; nothing committed.
.jira/config.yml
.jira/config.yml.bkp

# Project-local jira-cli binary — installed by scripts/install-jira-cli.sh.
bin/

# Generated by tools/viewer.sh — local index of agent-log files.
tools/log-index.json

# Per-user Claude Code overrides — keep out of the shared repo.
.claude/settings.local.json
